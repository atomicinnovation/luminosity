**/__pycache__/
**/test-results/
*-workspace/
*.egg-info/
*.iml
*.ipr
*.iws
*.swp
*.tsbuildinfo
*~
.DS_Store
.accelerator/config.local.md
# Personal config (git-ignored) and the atomic-write scratch dir; the team file
# `.luminosity/config.md` stays tracked. `**/` keeps the rule depth-independent
# so a `.luminosity/` discovered below the repo root is still matched.
**/.luminosity/config.local.md
**/.luminosity/tmp/
# …except the eval fixtures, which deliberately commit a personal config to
# exercise the precedence + malformed-frontmatter paths.
!tests/evals/skills/configure/fixtures/**/config.local.md
.claude/settings.local.json
# Local mise overrides may carry secrets (e.g. ANTHROPIC_API_KEY for the eval
# tier's live run) — never commit them.
mise.local.toml
.idea/
.playwright-mcp/
.pytest_cache/
.venv/
__pycache__/
workspaces/
node_modules/
target/
.pup/
# Staged release binaries + debug archives + per-binary signatures and the
# signed-manifest asset are build output; the committed release metadata beside
# them (checksums.json, manifest.json, keys) is not.
cli/launcher/bin/luminosity-*
cli/launcher/bin/manifest.minisig
# minisign secret keys must never be committed — the release secret lives in
# the GitHub `release` environment; only public keys are tracked.
*.key
/keys/*.sec
