// cargo-pup inward-dependency rule: the `version` core may import only
// std / kernel / its own subtree — the sole enforcer while single-crate.
// Note `matches` is the RESOLVED module path; `allowed_only` is LITERAL use-path.
(
    lints: [
        Module((
            name: "version_core_imports_only_permitted",
            matches: Module("^luminosity::version::core($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel(::|$)",
                        "^crate::version::core(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
        Module((
            name: "launch_core_imports_only_permitted",
            matches: Module("^luminosity::launch::core($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel(::|$)",
                        "^crate::launch::core(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
    ],
)
